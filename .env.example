# ─── Agent EOA ────────────────────────────────────────────────────────────────
# Private key for the agent wallet (hex, with 0x prefix).
# This wallet signs all swap transactions and receives USDC fee payments.
AGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── Chain Configuration ─────────────────────────────────────────────────────
# 84532 = Base Sepolia (default, safe for testing)
# 8453  = Base Mainnet
CHAIN_ID=84532

# RPC URL (leave blank for public defaults)
RPC_URL=https://sepolia.base.org
# Also used by the existing MetaMask chat UI:
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org

# ─── USDC Addresses ──────────────────────────────────────────────────────────
USDC_ADDRESS_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ADDRESS_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_DECIMALS=6

# ─── Fee ─────────────────────────────────────────────────────────────────────
# USDC amount charged per agent request (x402 payment)
FEE_AMOUNT_USDC=0.01

# ─── Builder Code (ERC-8021) ─────────────────────────────────────────────────
# Hex string from base.dev – appended to every tx calldata for attribution
BUILDER_CODE=

# ─── Swap Mode ───────────────────────────────────────────────────────────────
# Set to "true" to use mock self-transactions instead of real Uniswap swaps
MOCK_SWAP=true

# ─── Pricing ─────────────────────────────────────────────────────────────────
# Used for gas cost USD calculations (update periodically or use oracle)
ETH_PRICE_USD=2700

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Used for:
#   - LLM command parsing (optional; fallback regex parser is used if unset)
#   - Cross-Exchange similarity matching (Polymarket ↔ Kalshi) via
#     text-embedding-3-small. Required for the "Cross-Exchange" predictions tab.
OPENAI_API_KEY=
